OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Exa — live external intelligence ("what changed since last time").
# Get a key at https://exa.ai. Without it, the app falls back to seeded research.
EXA_API_KEY=
# seeded = deterministic fallback (default). cached = fetch once + cache. live = real Exa calls.
RESEARCH_MODE=live

# Use demo for first run (checks pass with no infra). Switch to neo4j only after the database is reachable and seeded.
DATA_MODE=demo
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=
